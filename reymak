<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>REYMAK Store</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #eef2f5;
    }

    header {
      background: #1e2a38;
      color: white;
      padding: 15px;
      text-align: center;
      font-size: 24px;
    }

    .container {
      padding: 20px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }

    .card {
      background: white;
      border-radius: 15px;
      overflow: hidden;
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
      transition: 0.3s;
    }

    .card:hover {
      transform: scale(1.03);
    }

    .card img {
      width: 100%;
    }

    .card-content {
      padding: 15px;
    }

    button {
      background: #1e2a38;
      color: white;
      border: none;
      padding: 10px;
      width: 100%;
      border-radius: 10px;
      cursor: pointer;
    }

    .cart {
      position: fixed;
      top: 15px;
      right: 15px;
      background: #1e2a38;
      color: white;
      padding: 15px;
      border-radius: 15px;
    }
  </style>
</head>

<body>

<header>REYMAK Store</header>

<div class="cart" id="cart">
  🛒 0 | $0
</div>

<div class="container">
  <div class="grid" id="productos"></div>
</div>

<script>
  const productos = [
    {
      nombre: "Compresor de aire",
      precio: 3200,
      imagen: "https://via.placeholder.com/300x200?text=Compresor"
    },
    {
      nombre: "Válvula de freno",
      precio: 850,
      imagen: "https://via.placeholder.com/300x200?text=Valvula"
    },
    {
      nombre: "Manguera industrial",
      precio: 450,
      imagen: "https://via.placeholder.com/300x200?text=Manguera"
    }
  ];

  let carrito = [];

  function actualizarCarrito() {
    const total = carrito.reduce((acc, p) => acc + p.precio, 0);
    document.getElementById("cart").innerText = `🛒 ${carrito.length} | $${total}`;
  }

  function agregarAlCarrito(producto) {
    carrito.push(producto);
    actualizarCarrito();
  }

  const contenedor = document.getElementById("productos");

  productos.forEach(p => {
    const card = document.createElement("div");
    card.className = "card";

    card.innerHTML = `
      <img src="${p.imagen}">
      <div class="card-content">
        <h3>${p.nombre}</h3>
        <p>$${p.precio}</p>
        <button>Agregar al carrito</button>
      </div>
    `;

    card.querySelector("button").onclick = () => agregarAlCarrito(p);

    contenedor.appendChild(card);
  });
</script>

</body>
</html>
